# --- Core ---
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/stock_valuation

# --- LLM (set at least ONE, matching LLM_PROVIDER) ---
LLM_PROVIDER=openai          # openai | groq | anthropic
OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- News (optional — falls back to a stub provider if unset) ---
NEWS_API_KEY=

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Storage ---
UPLOAD_DIR=/app/uploads
VECTOR_STORE_DIR=/app/vector_store
